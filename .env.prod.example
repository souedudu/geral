# =====================================================================
# Stack unificada — variáveis de produção compartilhadas entre os serviços
# Copie para .env.prod e preencha. NÃO commitar .env.prod.
# Gere senhas: openssl rand -base64 32
# =====================================================================

# ----- MySQL compartilhado -----
MYSQL_ROOT_PASSWORD=TROQUE_SENHA_FORTE_ROOT
APP_DB_USER=app
APP_DB_PASSWORD=TROQUE_SENHA_FORTE_DB

# ----- Redis compartilhado -----
REDIS_PASSWORD=TROQUE_SENHA_FORTE_REDIS

# ----- Domínios (lar usa HTTPS com cert Let's Encrypt) -----
LAR_DOMAIN=xn--larpadronizao-7eb3d.com.br
LAR_WWW_DOMAIN=www.xn--larpadronizao-7eb3d.com.br
LAR_CERTBOT_EMAIL=seu-email@dominio.com.br

# ----- Restaurante (HTTP por IP, tenant via sslip.io) -----
RESTAURANTE_PUBLIC_HOST=143.95.213.17
RESTAURANTE_API_BASE=http://143.95.213.17

# ----- Frontend Vite build args -----
VITE_API_URL=http://143.95.213.17
VITE_PUSHER_APP_KEY=
VITE_PUSHER_APP_CLUSTER=mt1

# ----- Evolution API (usada pelo lar) -----
EVOLUTION_SERVER_URL=https://xn--larpadronizao-7eb3d.com.br/evolution
EVOLUTION_API_KEY=TROQUE_API_KEY_FORTE
EVOLUTION_PG_USER=evolution
EVOLUTION_PG_PASSWORD=TROQUE_SENHA_PG
EVOLUTION_PG_DB=evolution
